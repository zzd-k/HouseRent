{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { useRouter } from 'vue-router';\nexport default {\n  data() {\n    return {\n      form: {\n        username: '',\n        password: ''\n      }\n    };\n  },\n  setup() {\n    const router = useRouter();\n    return {\n      router\n    };\n  },\n  methods: {\n    async login() {\n      try {\n        const response = await axios.post('/user/login', this.form);\n        if (response.data.code === 200) {\n          alert('登录成功！');\n          this.router.push('/home'); // 登录成功后跳转到主页\n        } else {\n          alert(response.data.message || '登录失败，请重试');\n        }\n      } catch (error) {\n        console.error(error);\n        alert('后端服务异常，请检查连接');\n      }\n    },\n    toRegister() {\n      this.router.push('/register'); // 跳转到注册页面\n    }\n  }\n};","map":{"version":3,"names":["useRouter","data","form","username","password","setup","router","methods","login","response","axios","post","code","alert","push","message","error","console","toRegister"],"sources":["F:\\2024毕设项目\\vuerent\\src\\views\\Login.vue"],"sourcesContent":["<template>\r\n    <el-container>\r\n      <el-header>\r\n        <h2>登录页面</h2>\r\n      </el-header>\r\n      <el-main>\r\n        <el-form :model=\"form\" label-width=\"80px\">\r\n          <el-form-item label=\"用户名\">\r\n            <el-input v-model=\"form.username\" />\r\n          </el-form-item>\r\n          <el-form-item label=\"密码\">\r\n            <el-input type=\"password\" v-model=\"form.password\" />\r\n          </el-form-item>\r\n          <el-form-item>\r\n            <el-button type=\"primary\" @click=\"login\">登录</el-button>\r\n            <el-button type=\"text\" @click=\"toRegister\">注册</el-button>\r\n          </el-form-item>\r\n        </el-form>\r\n      </el-main>\r\n    </el-container>\r\n  </template>\r\n  \r\n  <script>\r\n\r\n  import { useRouter } from 'vue-router';\r\n  \r\n  export default {\r\n    data() {\r\n      return {\r\n        form: {\r\n          username: '',\r\n          password: '',\r\n        },\r\n      };\r\n    },\r\n    setup() {\r\n      const router = useRouter();\r\n      return { router };\r\n    },\r\n    methods: {\r\n      async login() {\r\n        try {\r\n          const response = await axios.post('/user/login', this.form);\r\n          if (response.data.code === 200) {\r\n            alert('登录成功！');\r\n            this.router.push('/home'); // 登录成功后跳转到主页\r\n          } else {\r\n            alert(response.data.message || '登录失败，请重试');\r\n          }\r\n        } catch (error) {\r\n          console.error(error);\r\n          alert('后端服务异常，请检查连接');\r\n        }\r\n      },\r\n      toRegister() {\r\n        this.router.push('/register'); // 跳转到注册页面\r\n      },\r\n    },\r\n  };\r\n  </script>\r\n  "],"mappings":";AAwBE,SAASA,SAAQ,QAAS,YAAY;AAEtC,eAAe;EACbC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,IAAI,EAAE;QACJC,QAAQ,EAAE,EAAE;QACZC,QAAQ,EAAE;MACZ;IACF,CAAC;EACH,CAAC;EACDC,KAAKA,CAAA,EAAG;IACN,MAAMC,MAAK,GAAIN,SAAS,CAAC,CAAC;IAC1B,OAAO;MAAEM;IAAO,CAAC;EACnB,CAAC;EACDC,OAAO,EAAE;IACP,MAAMC,KAAKA,CAAA,EAAG;MACZ,IAAI;QACF,MAAMC,QAAO,GAAI,MAAMC,KAAK,CAACC,IAAI,CAAC,aAAa,EAAE,IAAI,CAACT,IAAI,CAAC;QAC3D,IAAIO,QAAQ,CAACR,IAAI,CAACW,IAAG,KAAM,GAAG,EAAE;UAC9BC,KAAK,CAAC,OAAO,CAAC;UACd,IAAI,CAACP,MAAM,CAACQ,IAAI,CAAC,OAAO,CAAC,EAAE;QAC7B,OAAO;UACLD,KAAK,CAACJ,QAAQ,CAACR,IAAI,CAACc,OAAM,IAAK,UAAU,CAAC;QAC5C;MACF,EAAE,OAAOC,KAAK,EAAE;QACdC,OAAO,CAACD,KAAK,CAACA,KAAK,CAAC;QACpBH,KAAK,CAAC,cAAc,CAAC;MACvB;IACF,CAAC;IACDK,UAAUA,CAAA,EAAG;MACX,IAAI,CAACZ,MAAM,CAACQ,IAAI,CAAC,WAAW,CAAC,EAAE;IACjC;EACF;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}