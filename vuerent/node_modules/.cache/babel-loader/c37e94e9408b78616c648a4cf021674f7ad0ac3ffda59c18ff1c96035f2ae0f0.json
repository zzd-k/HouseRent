{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { useRouter } from 'vue-router';\nexport default {\n  data() {\n    return {\n      form: {\n        username: '',\n        password: '',\n        email: ''\n      }\n    };\n  },\n  setup() {\n    const router = useRouter();\n    return {\n      router\n    };\n  },\n  methods: {\n    async register() {\n      try {\n        const response = await axios.post('/api/user/register', this.form);\n        if (response.data.code === 200) {\n          alert('注册成功，请登录！');\n          this.router.push('/login'); // 注册成功后跳转到登录页面\n        } else {\n          alert(response.data.message || '注册失败，请重试');\n        }\n      } catch (error) {\n        console.error(error);\n        alert('后端服务异常，请检查连接');\n      }\n    },\n    toLogin() {\n      this.router.push('/login'); // 跳转到登录页面\n    }\n  }\n};","map":{"version":3,"names":["useRouter","data","form","username","password","email","setup","router","methods","register","response","axios","post","code","alert","push","message","error","console","toLogin"],"sources":["F:\\2024毕设项目\\vuerent\\src\\views\\Register.vue"],"sourcesContent":["<template>\r\n    <el-container>\r\n      <el-header>\r\n        <h2>注册页面</h2>\r\n      </el-header>\r\n      <el-main>\r\n        <el-form :model=\"form\" label-width=\"80px\">\r\n          <el-form-item label=\"用户名\">\r\n            <el-input v-model=\"form.username\" />\r\n          </el-form-item>\r\n          <el-form-item label=\"密码\">\r\n            <el-input type=\"password\" v-model=\"form.password\" />\r\n          </el-form-item>\r\n          <el-form-item label=\"邮箱\">\r\n            <el-input v-model=\"form.email\" />\r\n          </el-form-item>\r\n          <el-form-item>\r\n            <el-button type=\"success\" @click=\"register\">注册</el-button>\r\n            <el-button type=\"text\" @click=\"toLogin\">返回登录</el-button>\r\n          </el-form-item>\r\n        </el-form>\r\n      </el-main>\r\n    </el-container>\r\n  </template>\r\n  \r\n  <script>\r\n  \r\n  import { useRouter } from 'vue-router';\r\n  \r\n  export default {\r\n    data() {\r\n      return {\r\n        form: {\r\n          username: '',\r\n          password: '',\r\n          email: '',\r\n        },\r\n      };\r\n    },\r\n    setup() {\r\n      const router = useRouter();\r\n      return { router };\r\n    },\r\n    methods: {\r\n      async register() {\r\n        try {\r\n          const response = await axios.post('/api/user/register', this.form);\r\n          if (response.data.code === 200) {\r\n            alert('注册成功，请登录！');\r\n            this.router.push('/login'); // 注册成功后跳转到登录页面\r\n          } else {\r\n            alert(response.data.message || '注册失败，请重试');\r\n          }\r\n        } catch (error) {\r\n          console.error(error);\r\n          alert('后端服务异常，请检查连接');\r\n        }\r\n      },\r\n      toLogin() {\r\n        this.router.push('/login'); // 跳转到登录页面\r\n      },\r\n    },\r\n  };\r\n  </script>\r\n  "],"mappings":";AA2BE,SAASA,SAAQ,QAAS,YAAY;AAEtC,eAAe;EACbC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,IAAI,EAAE;QACJC,QAAQ,EAAE,EAAE;QACZC,QAAQ,EAAE,EAAE;QACZC,KAAK,EAAE;MACT;IACF,CAAC;EACH,CAAC;EACDC,KAAKA,CAAA,EAAG;IACN,MAAMC,MAAK,GAAIP,SAAS,CAAC,CAAC;IAC1B,OAAO;MAAEO;IAAO,CAAC;EACnB,CAAC;EACDC,OAAO,EAAE;IACP,MAAMC,QAAQA,CAAA,EAAG;MACf,IAAI;QACF,MAAMC,QAAO,GAAI,MAAMC,KAAK,CAACC,IAAI,CAAC,oBAAoB,EAAE,IAAI,CAACV,IAAI,CAAC;QAClE,IAAIQ,QAAQ,CAACT,IAAI,CAACY,IAAG,KAAM,GAAG,EAAE;UAC9BC,KAAK,CAAC,WAAW,CAAC;UAClB,IAAI,CAACP,MAAM,CAACQ,IAAI,CAAC,QAAQ,CAAC,EAAE;QAC9B,OAAO;UACLD,KAAK,CAACJ,QAAQ,CAACT,IAAI,CAACe,OAAM,IAAK,UAAU,CAAC;QAC5C;MACF,EAAE,OAAOC,KAAK,EAAE;QACdC,OAAO,CAACD,KAAK,CAACA,KAAK,CAAC;QACpBH,KAAK,CAAC,cAAc,CAAC;MACvB;IACF,CAAC;IACDK,OAAOA,CAAA,EAAG;MACR,IAAI,CAACZ,MAAM,CAACQ,IAAI,CAAC,QAAQ,CAAC,EAAE;IAC9B;EACF;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}